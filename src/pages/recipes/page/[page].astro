---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Pagination from '../../../components/Pagination.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

const RECIPES_PER_PAGE = 9;

export async function getStaticPaths() {
  const recipes = (await getCollection('recipes')).sort((a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf());
  const totalPages = Math.ceil(recipes.length / RECIPES_PER_PAGE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, idx) => {
    const page = idx + 2;
    const start = (page - 1) * RECIPES_PER_PAGE;
    const end = start + RECIPES_PER_PAGE;

    return {
      params: { page: String(page) },
      props: {
        recipes: recipes.slice(start, end),
        currentPage: page,
        totalPages,
      },
    };
  });
}

const { recipes, currentPage, totalPages } = Astro.props;
---

<html lang="id">
  <head>
    <BaseHead title={`Resep - Halaman ${currentPage} - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[#960402] text-white">
    <Header />
    <main class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#ffbeb2]">Resep</p>
        <h1 class="mt-3 text-4xl font-black uppercase tracking-tight sm:text-5xl">Aneka Resep</h1>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {recipes.map((recipe) => (
          <a href={`/recipes/${recipe.data.slug}/`} class="group overflow-hidden rounded-3xl border border-[#bf2f20] bg-[#7f0907] transition hover:-translate-y-1 hover:border-[#ff8368]">
            <img src={recipe.data.mainImage} alt={recipe.data.title} class="h-56 w-full object-cover" />
            <div class="p-5">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-[#ffb9ac]"><FormattedDate date={recipe.data.releaseDate} /></p>
              <h2 class="mt-2 text-2xl font-extrabold text-[#fff1ee]">{recipe.data.title}</h2>
            </div>
          </a>
        ))}
      </div>

      <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/recipes" />
    </main>
    <Footer />
  </body>
</html>
