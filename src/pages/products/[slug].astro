---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const products = await getCollection('products');
	return products.map((product) => ({
		params: { slug: product.data.slug },
		props: product,
	}));
}

type Props = CollectionEntry<'products'>;

const product = Astro.props;
const { Content } = await render(product);

const brands = await getCollection('brands');
const categories = await getCollection('categories');
const brand = brands.find((item) => item.data.slug === product.data.brand);
const category = categories.find((item) => item.data.slug === product.data.category);
const currency = new Intl.NumberFormat('id-ID', {
	style: 'currency',
	currency: 'IDR',
	maximumFractionDigits: 0,
});
const hasDiscount = typeof product.data.discountPrice === 'number' && product.data.discountPrice < product.data.price;
const finalPrice = hasDiscount ? (product.data.discountPrice ?? product.data.price) : product.data.price;
---

<html lang="id">
	<head>
		<BaseHead title={`${product.data.name} - ${SITE_TITLE}`} description={product.data.description} image={product.data.mainImage} />
	</head>
	<body class="bg-[#960402] text-white">
		<Header />
		<main class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
			<a href="/products" class="text-sm font-semibold text-[#ffd8cf] hover:text-white">&larr; Kembali ke produk</a>
			<section class="mt-6 grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
				<div class="overflow-hidden rounded-3xl border border-[#bf2f20] bg-[#7f0907]">
					<img src={product.data.mainImage} alt={product.data.name} class="h-full w-full object-cover" />
				</div>
				<div class="space-y-6">
					<div>
						<p class="text-xs font-bold uppercase tracking-[0.3em] text-[#ffbeb2]">{brand?.data.name ?? product.data.brand}</p>
						<h1 class="mt-3 text-4xl font-black uppercase tracking-tight">{product.data.name}</h1>
					</div>

					<div class="rounded-3xl border border-[#bf2f20] bg-[#7f0907] p-6">
						<div class="flex flex-wrap items-end justify-between gap-4">
							<div>
								<p class="text-sm text-[#ffbea7]">Kategori</p>
								<p class="text-[#fff1ee]">{category?.data.name ?? product.data.category}</p>
							</div>
							<div class="text-right">
								{hasDiscount && <p class="text-sm text-[#ffad9f] line-through">{currency.format(product.data.price)}</p>}
								<p class="text-3xl font-extrabold text-[#fff1ee]">{currency.format(finalPrice)}</p>
							</div>
						</div>
						<p class="mt-5 text-base leading-7 text-[#ffd5ce]">{product.data.description}</p>

						<div class="mt-6 flex flex-wrap items-end gap-3">
							<input id="product-qty" type="number" min="1" value="1" class="w-24 rounded-xl border border-[#bf2f20] bg-[#8f1410] px-3 py-2 text-[#fff1ee] outline-none ring-0" />
							<button
								type="button"
								class="js-add-to-cart rounded-xl border border-[#bf2f20] bg-[#f03b0f] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#d9340d]"
								data-qty-input-id="product-qty"
								data-product-slug={product.data.slug}
								data-product-name={product.data.name}
								data-product-image={product.data.mainImage}
								data-product-price={finalPrice}
							>
								+ Tambah ke keranjang
							</button>
						</div>
					</div>

					<div class="grid gap-4 sm:grid-cols-3">
						{product.data.gallery.map((image) => (
							<img src={image} alt={product.data.name} class="h-32 w-full rounded-2xl border border-[#bf2f20] object-cover" />
						))}
					</div>
				</div>
			</section>

			<section class="prose prose-invert mt-12 max-w-none prose-headings:text-[#fff1ee] prose-p:text-[#ffe7e1] prose-strong:text-white prose-a:text-[#ffd8cf]">
				<Content />
			</section>
		</main>
		<Footer />
	</body>
</html>