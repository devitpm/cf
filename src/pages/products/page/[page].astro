---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import Pagination from '../../../components/Pagination.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

const PRODUCTS_PER_PAGE = 8;

export async function getStaticPaths() {
  const products = await getCollection('products');
  const totalPages = Math.ceil(products.length / PRODUCTS_PER_PAGE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, idx) => {
    const page = idx + 2;
    const start = (page - 1) * PRODUCTS_PER_PAGE;
    const end = start + PRODUCTS_PER_PAGE;

    return {
      params: { page: String(page) },
      props: {
        products: products.slice(start, end),
        currentPage: page,
        totalPages,
      },
    };
  });
}

const brands = await getCollection('brands');
const categories = await getCollection('categories');
const brandMap = new Map(brands.map((brand) => [brand.data.slug, brand.data]));
const categoryMap = new Map(categories.map((category) => [category.data.slug, category.data]));

const currency = new Intl.NumberFormat('id-ID', {
  style: 'currency',
  currency: 'IDR',
  maximumFractionDigits: 0,
});

const { products, currentPage, totalPages } = Astro.props;
---

<html lang="id">
  <head>
    <BaseHead title={`Produk - Halaman ${currentPage} - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[#960402] text-white">
    <Header />
    <main class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#ffbeb2]">Produk</p>
        <h1 class="mt-3 text-4xl font-black uppercase tracking-tight sm:text-5xl">Katalog cahaya foodies</h1>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        {products.map((product) => {
          const brand = brandMap.get(product.data.brand);
          const category = categoryMap.get(product.data.category);
          const discounted = typeof product.data.discountPrice === 'number' && product.data.discountPrice < product.data.price;
          const finalPrice = discounted ? (product.data.discountPrice ?? product.data.price) : product.data.price;

          return (
            <article class="group overflow-hidden rounded-3xl border border-[#bf2f20] bg-[#7f0907] transition hover:-translate-y-1 hover:border-[#ff8368]">
              <a href={`/products/${product.data.slug}/`}>
                <img src={product.data.mainImage} alt={product.data.name} class="h-56 w-full object-cover transition duration-300 group-hover:scale-105" />
              </a>
              <div class="space-y-4 p-5">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.25em] text-[#ffb9ac]">{brand?.name ?? product.data.brand}</p>
                  <h2 class="mt-2 text-xl font-extrabold text-[#fff1ee]">{product.data.name}</h2>
                </div>
                <p class="text-sm leading-6 text-[#ffd5ce]">{product.data.description}</p>
                <div class="flex items-end justify-between gap-3 text-sm text-[#ffceb8]">
                  <div>
                    <p>{category?.name ?? product.data.category}</p>
                    <p>{brand?.name ?? product.data.brand}</p>
                  </div>
                  <div class="text-right">
                    {discounted && <p class="text-xs text-[#ffad9f] line-through">{currency.format(product.data.price)}</p>}
                    <p class="text-lg font-extrabold text-[#fff1ee]">{currency.format(finalPrice)}</p>
                  </div>
                </div>
                <div class="flex gap-2 pt-1">
                  <a href={`/products/${product.data.slug}/`} class="flex-1 rounded-xl border border-[#bf2f20] bg-[#8f1410] px-3 py-2 text-center text-sm font-semibold text-[#fff1ee] transition hover:border-[#ff8368] hover:bg-[#a71913]">Detail</a>
                  <button
                    type="button"
                    class="js-add-to-cart flex-1 rounded-xl border border-[#bf2f20] bg-[#f03b0f] px-3 py-2 text-sm font-semibold text-white transition hover:bg-[#d9340d]"
                    data-product-slug={product.data.slug}
                    data-product-name={product.data.name}
                    data-product-image={product.data.mainImage}
                    data-product-price={finalPrice}
                  >
                    + Keranjang
                  </button>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/products" />
    </main>
    <Footer />
  </body>
</html>
