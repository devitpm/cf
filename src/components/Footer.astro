---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="site-footer">
	<div class="footer-main mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-3 lg:px-8">
		<section>
			<a href="/" class="inline-flex items-center gap-3">
				<img src="/logo-putih.png" alt="Cahayafoodies" class="h-12 w-auto" />
			</a>
			<p class="mt-5 max-w-sm text-lg leading-9 text-[#ffe7e1]">
				Berbagai produk olahan daging ayam, sapi, nugget, sosis, dan saos dari brand terpercaya. Kualitas premium untuk kebutuhan bisnis dan rumah tangga Anda.
			</p>
			<div class="mt-8 flex items-center gap-4">
				<a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Facebook">
					<i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
				</a>
				<a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
					<i class="fa-brands fa-instagram" aria-hidden="true"></i>
				</a>
				<a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="YouTube">
					<i class="fa-brands fa-youtube" aria-hidden="true"></i>
				</a>
			</div>
		</section>

		<section>
			<h2 class="footer-title">LINK CEPAT</h2>
			<nav class="mt-7 flex flex-col gap-4 text-lg font-semibold text-white">
				<a href="/about" class="footer-link">Tentang Kami</a>
				<a href="/products" class="footer-link">Produk</a>
				<a href="/recipes" class="footer-link">Resep</a>
				<a href="https://wa.me/628991245050" target="_blank" rel="noopener noreferrer" class="footer-link">Hubungi</a>
			</nav>
		</section>

		<section>
			<h2 class="footer-title">SKMEAT.ID</h2>
			<ul class="mt-7 space-y-4 text-white">
				<li class="contact-row">
					<i class="fa-solid fa-location-dot" aria-hidden="true"></i>
					<span>Suko, Menang, Pagu, Kediri, 64183</span>
				</li>
				<li class="contact-row">
					<i class="fa-solid fa-phone" aria-hidden="true"></i>
					<span>+62 812 1579 9522</span>
				</li>
				<li class="contact-row">
					<i class="fa-solid fa-envelope" aria-hidden="true"></i>
					<span>hi@cahayafoodies.com</span>
				</li>
				<li class="contact-row">
					<i class="fa-solid fa-clock" aria-hidden="true"></i>
					<span>07.00 AM - 19.00 PM</span>
				</li>
			</ul>
		</section>
	</div>

	<div class="footer-bottom px-4 py-4 text-center text-xl text-white sm:px-6">
		{SITE_TITLE} &copy; {today.getFullYear()}. All rights reserved.
	</div>
</footer>
<style>
	.site-footer {
		background: #9f3338;
	}

	.footer-main {
		align-items: start;
	}

	.footer-title {
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #fff;
	}

	.footer-link {
		transition: color 0.2s ease;
	}

	.footer-link:hover {
		color: #ffd8cc;
	}

	.social-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 34px;
		width: 34px;
		border-radius: 999px;
		background: #7e0002;
		color: #ffcf2b;
		text-decoration: none;
		transition: transform 0.2s ease, filter 0.2s ease;
	}

	.social-icon:hover {
		transform: translateY(-1px);
		filter: brightness(1.08);
	}

	.contact-row {
		display: grid;
		grid-template-columns: 20px 1fr;
		gap: 14px;
		align-items: start;
		font-size: 1rem;
		line-height: 1.6;
	}

	.contact-row i {
		margin-top: 0.45rem;
		font-size: 1rem;
	}

	.footer-bottom {
		background: #f13308;
	}

	@media (max-width: 1024px) {
		.footer-title {
			font-size: 1.75rem;
		}

		.contact-row {
			font-size: 1.2rem;
		}
	}

	@media (max-width: 640px) {
		.footer-main {
			gap: 2.25rem;
			padding-top: 2.5rem;
			padding-bottom: 2.5rem;
		}

		.footer-title {
			font-size: 1.35rem;
		}

		.contact-row {
			font-size: 1rem;
		}

		.footer-bottom {
			font-size: 0.95rem;
		}
	}
</style>
