<header class="sticky top-0 z-50 border-b border-[#d3391f] bg-[#f03b0f]">
	<div class="nav-notch mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
		<a href="/" class="flex items-center gap-3">
			<img src="/logo-putih.png" alt="Cahayafoodies" class="h-10 w-auto" />
		</a>

		<nav class="hidden items-center gap-8 text-[20px] font-normal capitalize leading-none md:flex lg:text-lg">
			<a href="/categories" class="tracking-wide text-white transition hover:text-[#ffd8cc]">Kategori</a>
			<a href="/brands" class="tracking-wide text-white transition hover:text-[#ffd8cc]">Brand</a>
			<a href="/products" class="tracking-wide text-white transition hover:text-[#ffd8cc]">Produk</a>
			<a href="/about" class="tracking-wide text-white transition hover:text-[#ffd8cc]">Tentang Kami</a>
			<a href="/recipes" class="tracking-wide text-white transition hover:text-[#ffd8cc]">Resep</a>
			<a href="/blog" class="tracking-wide text-white transition hover:text-[#ffd8cc]">Blog</a>
		</nav>

		<div class="flex items-center gap-2 sm:gap-4">
			<a href="/cart"
				class="relative inline-flex items-center gap-1.5 text-[20px] font-bold leading-none lg:text-lg">
				<span data-cart-total>Rp0</span>
				<i class="fa-solid fa-cart-shopping text-lg sm:text-xl" aria-hidden="true"></i>
				<span
					class="absolute -right-2 -top-2 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-yellow-400 px-1 text-[10px] font-bold text-[#b42318]"
					data-cart-count>0</span>
			</a>

			<details class="mobile-menu md:hidden">
				<summary
					class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-md border border-white/30 bg-[#c62e12] text-lg text-white transition hover:bg-[#af260f]">
					<span class="icon-bars" aria-hidden="true">☰</span>
					<span class="icon-close" aria-hidden="true">✕</span>
					<span class="sr-only">Toggle menu</span>
				</summary>
				<div
					class="absolute right-4 top-[72px] z-50 w-[min(88vw,320px)] overflow-hidden rounded-2xl border border-[#d3391f] bg-[#8c0b09] shadow-2xl sm:right-6">
					<nav class="flex flex-col p-2 text-base font-extrabold uppercase">
						<a href="/categories" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Kategori</a>
						<a href="/brands" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Brand</a>
						<a href="/products" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Produk</a>
						<a href="/cart" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Keranjang</a>
						<a href="/about" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Tentang Kami</a>
						<a href="/recipes" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Resep</a>
						<a href="/blog" class="rounded-xl px-4 py-3 hover:bg-[#b51e13]">Blog</a>
					</nav>
				</div>
			</details>
		</div>
	</div>
</header>

<style>
	.nav-notch {
		position: relative;
	}

	.nav-notch::after {
		content: "";
		position: absolute;
		left: 50%;
		bottom: -15px;
		transform: translateX(-50%);
		width: 0;
		height: 0;
		border-left: 18px solid transparent;
		border-right: 18px solid transparent;
		border-top: 15px solid #f03b0f;
	}

	.mobile-menu summary {
		list-style: none;
	}

	.mobile-menu summary::-webkit-details-marker {
		display: none;
	}

	.mobile-menu .icon-close {
		display: none;
	}

	.mobile-menu .icon-bars,
	.mobile-menu .icon-close {
		font-size: 1.25rem;
		font-weight: 900;
		line-height: 1;
	}

	.mobile-menu[open] .icon-bars {
		display: none;
	}

	.mobile-menu[open] .icon-close {
		display: inline-block;
	}
</style>

<script is:inline>
	(() => {
		if (window.__cfCartEngineInitialized && window.CFCart?.refreshSummary) {
			window.CFCart.refreshSummary();
			return;
		}

		window.__cfCartEngineInitialized = true;

		const CART_KEY = 'cf-cart-v1';
		const currency = new Intl.NumberFormat('id-ID', {
			style: 'currency',
			currency: 'IDR',
			maximumFractionDigits: 0,
		});

		function readCart() {
			try {
				const value = localStorage.getItem(CART_KEY);
				const parsed = value ? JSON.parse(value) : [];
				return Array.isArray(parsed) ? parsed : [];
			} catch {
				return [];
			}
		}

		function writeCart(items) {
			localStorage.setItem(CART_KEY, JSON.stringify(items));
			window.dispatchEvent(new CustomEvent('cf-cart-updated'));
		}

		function getTotals(items) {
			const quantity = items.reduce((sum, item) => sum + item.qty, 0);
			const subtotal = items.reduce((sum, item) => sum + item.qty * item.price, 0);
			return { quantity, subtotal };
		}

		function updateCartSummary() {
			const items = readCart();
			const totals = getTotals(items);

			document.querySelectorAll('[data-cart-count]').forEach((node) => {
				node.textContent = String(totals.quantity);
			});

			document.querySelectorAll('[data-cart-total]').forEach((node) => {
				node.textContent = currency.format(totals.subtotal);
			});
		}

		function addItem(payload) {
			const items = readCart();
			const quantity = Number(payload.qty) > 0 ? Number(payload.qty) : 1;
			const existing = items.find((item) => item.slug === payload.slug);

			if (existing) {
				existing.qty += quantity;
			} else {
				items.push({
					slug: payload.slug,
					name: payload.name,
					image: payload.image,
					price: payload.price,
					qty: quantity,
				});
			}

			writeCart(items);
			return items;
		}

		function setQty(slug, qty) {
			const items = readCart();
			const target = items.find((item) => item.slug === slug);
			if (!target) {
				return items;
			}

			target.qty = Math.max(1, Number(qty) || 1);
			writeCart(items);
			return items;
		}

		function removeItem(slug) {
			const items = readCart().filter((item) => item.slug !== slug);
			writeCart(items);
			return items;
		}

		function clearCart() {
			writeCart([]);
			return [];
		}

		function buildWhatsappUrl(phone) {
			const cleanedPhone = String(phone || '').replace(/\D/g, '');
			const items = readCart();
			const totals = getTotals(items);

			if (items.length === 0) {
				return `https://wa.me/${cleanedPhone}`;
			}

			const lines = [
				'Halo Cahaya Foodies, saya ingin checkout pesanan berikut:',
				'',
				...items.map((item, index) => `${index + 1}. ${item.name} x${item.qty} = ${currency.format(item.qty * item.price)}`),
				'',
				`Total item: ${totals.quantity}`,
				`Total belanja: ${currency.format(totals.subtotal)}`,
				'',
				'Mohon konfirmasi ketersediaan dan ongkir. Terima kasih.',
			];

			return `https://wa.me/${cleanedPhone}?text=${encodeURIComponent(lines.join('\n'))}`;
		}

		window.CFCart = {
			addItem,
			clearCart,
			formatCurrency: (value) => currency.format(value),
			getCart: readCart,
			getTotals,
			removeItem,
			setQty,
			refreshSummary: updateCartSummary,
			buildWhatsappUrl,
		};

		document.addEventListener('click', (event) => {
			const button = event.target.closest('.js-add-to-cart');
			if (!button) {
				return;
			}

			event.preventDefault();

			const qtyInputId = button.dataset.qtyInputId;
			const qtyInput = qtyInputId ? document.getElementById(qtyInputId) : null;
			const qty = qtyInput ? Number(qtyInput.value) : 1;

			const price = Number(button.dataset.productPrice || 0);
			if (!button.dataset.productSlug || !button.dataset.productName || !price) {
				return;
			}

			addItem({
				slug: button.dataset.productSlug,
				name: button.dataset.productName,
				image: button.dataset.productImage || '',
				price,
				qty,
			});

			const originalText = button.textContent;
			button.textContent = 'Ditambahkan';
			setTimeout(() => {
				button.textContent = originalText;
			}, 1200);
		});

		window.addEventListener('storage', updateCartSummary);
		window.addEventListener('cf-cart-updated', updateCartSummary);
		document.addEventListener('astro:page-load', updateCartSummary);
		document.addEventListener('astro:after-swap', updateCartSummary);
		updateCartSummary();
	})();
</script>